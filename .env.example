# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional overrides (defaults shown) ──────────────────────────────────────

# OpenAI model used to generate embeddings.
# Changing this also changes VECTOR_DIM automatically (see config.py).
# Supported: text-embedding-3-small (1536-dim), text-embedding-3-large (3072-dim), text-embedding-ada-002 (1536-dim)
EMBEDDING_MODEL=text-embedding-3-small

# OpenAI chat model used for answer generation.
LLM_MODEL=gpt-4o-mini

# Minimum cosine similarity required to pass the guardrail.
# Raise this to be more conservative; lower it to allow fuzzier matches.
SIMILARITY_THRESHOLD=0.45

# Number of chunks retrieved per query when top_k is not specified by the caller.
DEFAULT_TOP_K=5

# Chunking parameters (characters).
CHUNK_SIZE=2200
CHUNK_OVERLAP=300

# Maximum file size accepted by POST /ingest (in megabytes).
MAX_UPLOAD_MB=50
